# .gitignore

# macOS system files
.DS_Store
**/.DS_Store
.env
.env.*
*.env

/creds/
creds/*

# Gemini API usage tracker
.gemini_usage.json

# Log files that may contain sensitive information
docs/log/

# Runtime-generated data (should not be in Git)
.chroma_categories/
.runtime/

# Claude Code workspace
.claude/

memory/

# Python cache
__pycache__/
*.pyc
*.pyo
